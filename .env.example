# ── SmartRAG Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose up

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                          # Your OpenAI API key
SECRET_KEY=replace-with-openssl-rand-hex-32    # App secret (run: openssl rand -hex 32)

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                         # development | staging | production
DEBUG=false

# ── LLM Settings ──────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini                          # Cheaper: gpt-4o-mini | Smarter: gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── RAG Engine ────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
HALLUCINATION_THRESHOLD=0.5

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://smartrag:smartrag@postgres:5432/smartrag
POSTGRES_USER=smartrag
POSTGRES_PASSWORD=smartrag
POSTGRES_DB=smartrag

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_QUERIES_PER_MIN=60
MAX_DOCUMENT_SIZE_MB=50
MAX_DOCUMENTS_PER_TENANT=500
